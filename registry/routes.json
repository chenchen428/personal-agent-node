{
  "schemaVersion": 2,
  "defaultPolicy": "deny",
  "routes": [
    { "pattern": "/", "access": "public", "capability": "publications" },
    { "pattern": "/blog/*", "access": "public", "capability": "publications" },
    { "pattern": "/pages/*", "access": "public", "capability": "publications" },
    { "pattern": "/docs/*", "access": "public", "capability": "publications" },
    { "pattern": "/resources/*", "access": "public", "capability": "publications" },
    { "pattern": "/app/pages", "access": "authenticated", "capability": "publications" },
    { "pattern": "/app/skills", "access": "authenticated", "capability": "skills" },
    { "pattern": "/app/update", "access": "local-admin", "capability": "runtime" },
    { "pattern": "/app/*", "access": "authenticated", "capability": "console" },
    { "pattern": "/api/app/*", "access": "authenticated", "capability": "console" },
    { "pattern": "/api/chat/*", "access": "authenticated", "capability": "agent" },
    { "pattern": "/api/channels/*", "access": "authenticated", "capability": "channels" },
    { "pattern": "/api/managed-platforms/*", "access": "authenticated", "capability": "managed-platforms" },
    { "pattern": "/api/publications/*", "access": "authenticated", "capability": "publications" },
    { "pattern": "/api/system/*", "access": "local-admin", "capability": "runtime" },
    { "pattern": "/api/extensions/*", "access": "local-admin", "capability": "extensions" },
    { "pattern": "/internal/*", "access": "internal", "capability": "runtime" }
  ]
}
