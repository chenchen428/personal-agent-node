{
  "schemaVersion": 1,
  "homeEnvironment": "PERSONAL_AGENT_HOME",
  "defaultHome": "~/.personal-agent",
  "core": {
    "path": "core",
    "ownership": "product",
    "mutable": false,
    "releasePointers": ["current", "previous"],
    "directories": ["bin", "releases"]
  },
  "workspace": {
    "path": "workspace",
    "ownership": "user",
    "mutable": true,
    "preserveOnUninstall": true,
    "harness": ["AGENTS.md", "registry", "skills", "workflows"],
    "directories": [
      "apps",
      "plugins",
      "files",
      "publications",
      "databases",
      "mail",
      "backups",
      "config",
      "secrets",
      "runtime",
      "logs"
    ]
  },
  "desktopShell": {
    "framework": "tauri-2",
    "ownership": "product",
    "serviceOwner": "desktop-client",
    "origin": "http://127.0.0.1:8843",
    "platforms": ["windows-x64", "macos-x64", "macos-arm64", "linux-x64", "linux-arm64"],
    "systemWebview": true,
    "bundledChromium": false,
    "bundledNodeSidecar": false,
    "browserFallback": true,
    "updates": {
      "unit": "platform-release",
      "coordinator": "personal-agent-control",
      "executor": "core/bin/personal-agent-setup",
      "handoffOwner": "desktop-client",
      "jobSchema": "schemas/personal-agent/update-job.schema.json",
      "automaticRestart": true,
      "automaticRollback": true,
      "localApprovalRisk": "R3",
      "productDevelopmentConfirmationPolicy": "never"
    }
  },
  "browserExecutors": {
    "opencli": {
      "ownership": "product",
      "package": "@jackwener/opencli",
      "version": "1.8.6",
      "bundled": true,
      "globalInstallRequired": false,
      "updateUnit": "platform-release",
      "installScripts": false,
      "browserBridge": {
        "bundled": false,
        "distribution": "chrome-web-store",
        "extensionId": "ildkmabpimmkaediidaifkhjpohdnifk",
        "userConfirmationRequired": true
      }
    }
  }
}
