      { "key": "api-token-usage", "prefix": "/api/token-usage", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/token-usage" },
      { "key": "api-connections", "prefix": "/api/connections", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/connections" },
