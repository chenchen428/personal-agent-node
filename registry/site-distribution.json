      { "key": "app-mail", "prefix": "/app/mail", "exact": true, "access": "authenticated", "kind": "proxy", "targetKey": "console", "upstreamPath": "/app/mail" },
      { "key": "app-data", "prefix": "/app/data", "access": "authenticated", "kind": "proxy", "targetKey": "console", "upstreamPath": "/app/data" },
