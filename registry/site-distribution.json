      { "key": "login", "prefix": "/login", "exact": true, "access": "public", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/login" },
      { "key": "logout", "prefix": "/logout", "exact": true, "access": "public", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/logout" },
