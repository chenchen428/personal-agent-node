      { "key": "resources", "prefix": "/resources", "access": "authenticated", "kind": "static" },
      { "key": "blog", "prefix": "/blog", "access": "authenticated", "kind": "static" },
      { "key": "docs", "prefix": "/docs", "access": "authenticated", "kind": "static" }
