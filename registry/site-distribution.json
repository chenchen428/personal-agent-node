{
  "schemaVersion": 2,
  "name": "personal-agent-node",
  "routing": {
    "defaultMode": "path",
    "defaultPolicy": "deny",
    "paths": [
      { "key": "home", "prefix": "/", "exact": true, "access": "public", "kind": "static" },
      { "key": "app-chat", "prefix": "/app/chat", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/agent-bridge", "websocket": true },
      { "key": "app-chat-memory", "prefix": "/app/chat/memory", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/agent-memory" },
      { "key": "app-channels", "prefix": "/app/channels", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/agent-channels" },
      { "key": "app-files", "prefix": "/app/files", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/private-files" },
      { "key": "app-mail", "prefix": "/app/mail", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/mail" },
      { "key": "app-automations", "prefix": "/app/automations", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/agent-automations" },
      { "key": "app-data", "prefix": "/app/data", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/agent-data" },
      { "key": "app-schedules", "prefix": "/app/schedules", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/agent-corn" },
      { "key": "app-pages", "prefix": "/app/pages", "access": "authenticated", "kind": "proxy", "targetKey": "pages", "upstreamPath": "/online-pages" },
      { "key": "app-releases", "prefix": "/app/releases", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/release-notes" },
      { "key": "app-skills", "prefix": "/app/skills", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/agent-skills" },
      { "key": "app-update", "prefix": "/app/update", "access": "local-admin", "kind": "proxy", "targetKey": "console", "upstreamPath": "/update" },
      { "key": "app", "prefix": "/app", "access": "authenticated", "kind": "proxy", "targetKey": "console", "upstreamPath": "/" },
      { "key": "api-app-data", "prefix": "/api/app/data", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/agent-data" },
      { "key": "api-app-automations", "prefix": "/api/app/automations", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/agent-automations" },
      { "key": "api-app-schedules", "prefix": "/api/app/schedules", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/agent-corn" },
      { "key": "api-app", "prefix": "/api/app", "access": "authenticated", "kind": "proxy", "targetKey": "console", "upstreamPath": "/api/app" },
      { "key": "api-chat-bridge", "prefix": "/api/chat/bridge", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/agent-bridge", "websocket": true },
      { "key": "api-chat-ws", "prefix": "/api/chat/ws", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/ws", "websocket": true },
      { "key": "api-chat", "prefix": "/api/chat", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api" },
      { "key": "api-channels", "prefix": "/api/channels", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/channels" },
      { "key": "api-managed-platforms", "prefix": "/api/managed-platforms", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/managed-platforms" },
      { "key": "api-publications", "prefix": "/api/publications", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/pages" },
      { "key": "api-system", "prefix": "/api/system", "access": "local-admin", "kind": "proxy", "targetKey": "console", "upstreamPath": "/api" },
      { "key": "api-extensions", "prefix": "/api/extensions", "access": "local-admin", "kind": "proxy", "targetKey": "console", "upstreamPath": "/api/extensions" },
      { "key": "pages", "prefix": "/pages", "access": "public", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/pages" },
      { "key": "resources", "prefix": "/resources", "access": "public", "kind": "static" },
      { "key": "blog", "prefix": "/blog", "access": "public", "kind": "static" },
      { "key": "docs", "prefix": "/docs", "access": "public", "kind": "static" }
    ]
  },
  "domain": {
    "apexEnv": "SITE_DOMAIN",
    "localSuffix": "local",
    "standardHosts": [
      { "key": "home", "label": "Personal Agent", "prefix": "", "access": "public", "kind": "static", "source": "projects/core/site-web/html/blog" }
    ],
    "legacyHosts": []
  },
  "services": [
    { "name": "agent-runtime", "port": 8788, "healthPath": "/health", "required": true },
    { "name": "agent-worker", "required": true },
    { "name": "personal-agent-console", "port": 8791, "healthPath": "/healthz", "required": true },
    { "name": "personal-agent-gateway", "port": 8843, "healthPath": "/__private-site/health", "required": true }
  ]
}
