      { "key": "app-token-usage", "prefix": "/app/token-usage", "access": "authenticated", "kind": "proxy", "targetKey": "console", "upstreamPath": "/app/token-usage" },
      { "key": "app-setup-bootstrap", "prefix": "/app/setup/bootstrap", "exact": true, "access": "local-bootstrap", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/setup/bootstrap" },
      { "key": "app-settings", "prefix": "/app/settings", "access": "local-admin", "kind": "proxy", "targetKey": "console", "upstreamPath": "/app/settings" },
      { "key": "app-setup", "prefix": "/app/setup", "access": "local-admin", "kind": "proxy", "targetKey": "console", "upstreamPath": "/app/setup" },
      { "key": "app-update", "prefix": "/app/update", "access": "local-admin", "kind": "proxy", "targetKey": "console", "upstreamPath": "/app/update" },
      { "key": "app", "prefix": "/app", "access": "authenticated", "kind": "proxy", "targetKey": "console", "upstreamPath": "/app" },
      { "key": "api-app-data", "prefix": "/api/app/data", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/agent-data" },
      { "key": "api-app-schedules", "prefix": "/api/app/schedules", "access": "authenticated", "kind": "proxy", "targetKey": "agent", "upstreamPath": "/api/agent-corn" },
