{
  "schemaVersion": 2,
  "architecture": "next-core-workspace",
  "agentRuntime": {
    "supported": ["codex"],
    "workspaceDelivery": "workspace-harness",
    "compatibilityOnly": ["agents", "claude", "cursor"]
  },
  "delivery": {
    "homeEnvironment": "PERSONAL_AGENT_HOME",
    "defaultHome": "~/.personal-agent",
    "core": ["app", "runtime", "agent", "channels", "plugins"],
    "workspace": ["AGENTS.md", "registry", "skills", "workflows", "plugins", "files", "data", "databases", "mail", "backups", "config", "secrets", "runtime", "logs"]
  },
  "services": [
    { "id": "personal-agent-control", "kind": "local-socket" },
    { "id": "agent-runtime", "port": 8788 },
    { "id": "personal-agent-app", "port": 8791, "framework": "nextjs" },
    { "id": "personal-agent-control-api", "port": 8792, "visibility": "internal" },
    { "id": "personal-agent-gateway", "port": 8843 }
  ],
  "pluginContract": {
    "apiVersion": "personal-agent/v1",
    "manifest": "personal-agent.plugin.json",
    "schema": "core/plugins/schema/personal-agent.plugin.schema.json",
    "installRoot": "workspace/plugins",
    "dataRoot": "workspace/data/plugins",
    "mutableByLocalAgent": true,
    "edgeChangesRequired": false
  }
}
