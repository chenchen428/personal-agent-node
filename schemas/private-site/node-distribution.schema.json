{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal-agent.local/schemas/node-distribution.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "architecture", "agentRuntime", "delivery", "services", "pluginContract"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "architecture": { "const": "next-core-workspace" },
    "agentRuntime": { "type": "object" },
    "delivery": { "type": "object" },
    "services": { "type": "array" },
    "pluginContract": { "type": "object" }
  }
}
