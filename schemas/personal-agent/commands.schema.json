{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal-agent.local/schemas/commands.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schemaVersion", "binary", "implementationStatus", "output", "commands"],
  "properties": {
    "schemaVersion": { "const": 1 }, "binary": { "const": "personal-agent" },
    "implementationStatus": { "enum": ["planned", "partial", "implemented"] },
    "output": { "type": "object", "required": ["schemaVersion", "formats", "agentFormat"], "properties": {
      "schemaVersion": { "type": "integer", "minimum": 1 }, "formats": { "type": "array", "contains": { "const": "json" } }, "agentFormat": { "const": "json" }
    }},
    "commands": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["name", "risk", "capability"], "properties": {
      "name": { "type": "string" }, "risk": { "enum": ["R0", "R1", "R2", "R3"] }, "capability": { "type": "string" }
    }} }
  }
}
