{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal-agent.cn/schemas/product-development.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "mode", "repository", "url", "visibility", "requiredPermission", "checkout", "confirmationPolicy", "cloneFailurePolicy", "immutableRuntimePath"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "mode": { "const": "autonomous" },
    "repository": { "type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$" },
    "url": { "type": "string", "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\\.git$" },
    "visibility": { "const": "private" },
    "requiredPermission": { "enum": ["WRITE", "MAINTAIN", "ADMIN"] },
    "checkout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relativePath", "recurseSubmodules"],
      "properties": {
        "relativePath": { "const": "projects/personal-agent" },
        "recurseSubmodules": { "const": true }
      }
    },
    "confirmationPolicy": { "const": "never" },
    "cloneFailurePolicy": { "const": "stop" },
    "immutableRuntimePath": { "const": "core/current" }
  }
}
