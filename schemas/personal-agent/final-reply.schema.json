{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://personal-agent.local/schemas/personal-agent/final-reply.schema.json",
  "title": "Personal Agent final reply",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestId", "idempotencyKey", "text", "attachments"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "requestId": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "idempotencyKey": { "type": "string", "minLength": 1, "maxLength": 160, "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "text": { "type": "string", "maxLength": 40000 },
    "attachments": {
      "type": "array",
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["objectId"],
        "properties": {
          "objectId": { "type": "string", "pattern": "^obj_[a-f0-9]{24}$" },
          "alt": { "type": "string", "maxLength": 500 },
          "caption": { "type": "string", "maxLength": 1000 },
          "displayName": { "type": "string", "maxLength": 300 }
        }
      }
    }
  }
}
