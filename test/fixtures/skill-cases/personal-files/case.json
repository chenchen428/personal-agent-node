{
  "schemaVersion": 1,
  "skill": "personal-files",
  "title": "当前空间受管文件检索与安全交付",
  "prompt": "在当前 Space 搜索并检查一个受管文件，只按稳定 obj_ ID 物化和交付。存储校验、GC 与 reconcile 必须先 dry-run；不得暴露绝对路径、file URL、loopback URL 或跨 Space 对象。",
  "commands": [
    "pa-cli file search --query <text> --json",
    "pa-cli file stat --id <object-id> --json",
    "pa-cli file materialize --id <object-id> --ttl 7d --task <task-id> --json",
    "pa-cli file verify-storage --json",
    "pa-cli file gc --dry-run --json"
  ],
  "artifacts": [{ "path": "expected.json", "label": "Managed-file safety expectation" }]
}
